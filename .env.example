# Copie este arquivo para .env e preencha com valores reais.
# O .env NÃO deve ser versionado (já está no .gitignore).

# Django
DJANGO_SECRET_KEY=troque-por-uma-string-aleatoria-longa
DJANGO_DEBUG=true

# JWT (SSO)
JWT_SECRET=troque-por-outra-string-aleatoria-longa

# PostgreSQL
POSTGRES_DB=tcc_sso
POSTGRES_USER=tcc
POSTGRES_PASSWORD=tcc_dev_password

# OAuth / Keycloak
# OAUTH_ISSUER  = URL pública (browser-facing) — vai na claim "iss" dos tokens
# OAUTH_INTERNAL = como o BACKEND alcança o Keycloak (rede Docker)
OAUTH_ISSUER=http://localhost:8180/realms/tcc
OAUTH_INTERNAL=http://keycloak:8080/realms/tcc
OAUTH_CLIENT_ID=tcc-backend
OAUTH_CLIENT_SECRET=tcc-backend-secret
OAUTH_REDIRECT_URI=http://localhost:18000/api/auth/callback
FRONTEND_URL=http://localhost:5173
